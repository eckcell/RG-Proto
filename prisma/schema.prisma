// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Lead {
  id                  String   @id @default(uuid())
  companyName         String
  uen                 String
  businessType        String
  additionalEmployees Int?
  contactName         String
  contactEmail        String
  contactPhone        String
  quoteData           String   // JSON string of quote results
  createdAt           DateTime @default(now())
}
