// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL") // uses speed-optimized connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  password      String
  role          String   @default("BROKER")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Insurer {
  id          String    @id @default(uuid())
  name        String
  fullName    String
  logoPath    String
  description String?
  active      Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Industry {
  id          String    @id @default(uuid())
  name        String    @unique // e.g., "Food & Beverage", "Retail", "Office"
  slug        String    @unique // e.g., "fnb", "retail", "office"
  active      Boolean   @default(true)
  products    Product[]
  templates   FormTemplate[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model FormTemplate {
  id          String    @id @default(uuid())
  name        String
  industryId  String
  industry    Industry  @relation(fields: [industryId], references: [id])
  config      String    // JSON configuration of steps and fields
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id            String   @id @default(uuid())
  insurerId     String
  insurer       Insurer  @relation(fields: [insurerId], references: [id])
  industryId    String?
  industry      Industry? @relation(fields: [industryId], references: [id])
  name          String
  productCode   String
  configuration String   // JSON blob of tiers/rates
  brochureUrl   String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Lead {
  id                  String   @id @default(uuid())
  companyName         String
  uen                 String
  businessType        String   // Shorthand/Slug from the form
  contactName         String
  contactEmail        String
  contactPhone        String
  profileData         String?  // NEW: JSON string for dynamic form answers
  quoteData           String   // JSON string of quote results
  status              String   @default("NEW")
  selectedInsurer     String?
  selectedProduct     String?
  selectedPremiumCents Int?
  internalNotes       String?
  emailSent           Boolean  @default(false)
  assignedTo          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now()) @updatedAt
}
