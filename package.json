{
  "name": "riskguard-compare",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && npx prisma db push --accept-data-loss && npx prisma db seed && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@vercel/blob": "^2.3.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.7",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "20.17.46",
    "@types/react": "19.1.6",
    "eslint": "9.28.0",
    "eslint-config-next": "16.1.6",
    "prettier": "3.8.1",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "5.8.3",
    "vitest": "4.1.0"
  }
}
